-
-class KeyboardShortcuts {
-    constructor() {
-        this.shortcuts = new Map();
-        this.enabled = true;
-        this.init();
-    }
-    
-    init() {
-        // Built-in shortcuts
-        this.register('ctrl+shift+n', this.toggleNexus.bind(this), 'NEXUS AI টগল করুন');
-        this.register('ctrl+shift+l', this.toggleListening.bind(this), 'শোনা টগল করুন');
