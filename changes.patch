+        rgba(0, 0, 0, 0.3) 100%
+    );
+    border-top: 1px solid var(--glass-border);
+    display: flex;
+    flex-direction: column;
+    gap: 10px;
+}
+
+.input-tools {
+    display: flex;
+    gap: 8px;
+    justify-content: center;
+}
+
+.tool-btn {
+    width: 36px;
+    height: 36px;
+    border: 1px solid var(--glass-border);
+    background: rgba(0, 240, 255, 0.1);
+    border-radius: 10px;
+    cursor: pointer;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    font-size: 1.1rem;
+    transition: all var(--speed-fast) ease;
+}
+
+.tool-btn:hover {
+    background: rgba(0, 240, 255, 0.3);
+    transform: scale(1.1);
+    box-shadow: 0 0 15px var(--cyan-glow);
+}
+
+.tool-btn:active {
+    transform: scale(0.95);
+}
+
+.input-wrapper {
+    display: flex;
+    gap: 8px;
+    align-items: center;
+}
+
+#chatInput {
+    flex: 1;
+    padding: 14px 18px;
+    background: rgba(0, 0, 0, 0.5);
+    border: 1px solid var(--glass-border);
+    border-radius: 25px;
+    color: var(--text-primary);
+    font-family: var(--font-bengali);
+    font-size: 0.95rem;
+    outline: none;
+    transition: all var(--speed-fast) ease;
+}
+
+#chatInput:focus {
+    border-color: var(--cyan);
+    box-shadow: 0 0 20px var(--cyan-glow);
+    background: rgba(0, 0, 0, 0.7);
+}
+
+#chatInput::placeholder {
+    color: var(--text-muted);
+}
+
+.send-btn {
+    width: 48px;
+    height: 48px;
+    border: none;
+    background: linear-gradient(135deg, var(--cyan), var(--magenta));
+    border-radius: 50%;
+    cursor: pointer;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    font-size: 1.3rem;
+    color: var(--bg-dark);
+    transition: all var(--speed-fast) ease;
+    box-shadow: 0 0 20px var(--cyan-glow);
+}
+
+.send-btn:hover {
+    transform: scale(1.1);
+    box-shadow: 0 0 30px var(--cyan-glow), 0 0 50px var(--magenta-glow);
+}
+
+.send-btn:active {
+    transform: scale(0.95);
+}
+
+/* Language Selector */
+.language-selector {
+    margin-left: auto;
+}
+
+.language-selector select {
+    padding: 6px 12px;
+    background: rgba(0, 0, 0, 0.4);
+    border: 1px solid var(--glass-border);
+    border-radius: 8px;
+    color: var(--text-primary);
+    font-size: 0.8rem;
+    cursor: pointer;
+    outline: none;
+    transition: all var(--speed-fast) ease;
+}
+
+.language-selector select:hover,
+.language-selector select:focus {
+    border-color: var(--cyan);
+    box-shadow: 0 0 10px var(--cyan-glow);
+}
+
+.language-selector select option {
+    background: var(--bg-dark);
+    color: var(--text-primary);
+}
+
+/* Enhanced Chat Messages */
+.chat-message {
+    padding: 14px 18px;
+    border-radius: 18px;
+    margin-bottom: 10px;
+    animation: messageSlideIn 0.3s ease;
+    max-width: 95%;
+    word-wrap: break-word;
+}
+
+@keyframes messageSlideIn {
+    from {
+        opacity: 0;
+        transform: translateY(10px);
+    }
+    to {
+        opacity: 1;
+        transform: translateY(0);
+    }
+}
+
+.chat-message.user {
+    background: linear-gradient(135deg, 
+        rgba(0, 240, 255, 0.2) 0%,
+        rgba(0, 200, 255, 0.1) 100%
+    );
+    border: 1px solid rgba(0, 240, 255, 0.3);
+    margin-left: 20px;
+}
+
+.chat-message.ai {
+    background: linear-gradient(135deg, 
+        rgba(255, 0, 255, 0.15) 0%,
+        rgba(150, 0, 200, 0.1) 100%
+    );
+    border: 1px solid rgba(255, 0, 255, 0.3);
+    margin-right: 20px;
+}
+
+.chat-message .message-sender {
+    font-size: 0.75rem;
+    color: var(--cyan);
+    margin-bottom: 6px;
+    font-weight: 600;
+}
+
+.chat-message.user .message-sender {
+    color: var(--teal);
+}
+
+.chat-message .message-text {
+    font-size: 0.95rem;
+    line-height: 1.5;
+    color: var(--text-primary);
+}
+
+/* Content Generation Buttons */
+.content-gen-modal {
+    position: fixed;
+    top: 50%;
+    left: 50%;
+    transform: translate(-50%, -50%);
+    width: 500px;
+    max-width: 90vw;
+    background: var(--glass-bg);
+    border: 1px solid var(--glass-border);
+    border-radius: 20px;
+    padding: 24px;
+    z-index: 1001;
+    backdrop-filter: blur(30px);
+    display: none;
+}
+
+.content-gen-modal.active {
+    display: block;
+    animation: modalZoomIn 0.3s ease;
+}
+
+.content-gen-modal h3 {
+    font-family: var(--font-display);
+    color: var(--cyan);
+    margin-bottom: 16px;
+    text-align: center;
+}
+
+.content-gen-modal input,
+.content-gen-modal textarea,
+.content-gen-modal select {
+    width: 100%;
+    padding: 12px 16px;
+    background: rgba(0, 0, 0, 0.4);
+    border: 1px solid var(--glass-border);
+    border-radius: 10px;
+    color: var(--text-primary);
+    font-family: var(--font-bengali);
+    margin-bottom: 12px;
+}
+
+.content-gen-modal input:focus,
+.content-gen-modal textarea:focus,
+.content-gen-modal select:focus {
+    outline: none;
+    border-color: var(--cyan);
+    box-shadow: 0 0 15px var(--cyan-glow);
+}
+
+.content-gen-modal .btn-row {
+    display: flex;
+    gap: 12px;
+    margin-top: 16px;
+}
+
+.content-gen-modal button {
+    flex: 1;
+    padding: 12px;
+    border: none;
+    border-radius: 10px;
+    cursor: pointer;
+    font-family: var(--font-bengali);
+    font-weight: 600;
+    transition: all var(--speed-fast) ease;
+}
+
+.content-gen-modal .btn-generate {
+    background: linear-gradient(135deg, var(--cyan), var(--magenta));
+    color: var(--bg-dark);
+}
+
+.content-gen-modal .btn-cancel {
+    background: rgba(255, 51, 102, 0.2);
+    color: var(--status-error);
+    border: 1px solid var(--status-error);
+}
+
+.content-gen-modal button:hover {
+    transform: translateY(-2px);
+    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
+}
+
+/* Generated Content Display */
+.generated-content {
+    background: rgba(0, 0, 0, 0.5);
+    border: 1px solid var(--cyan);
+    border-radius: 12px;
+    padding: 16px;
+    margin-top: 16px;
+    max-height: 300px;
+    overflow-y: auto;
+    font-family: var(--font-mono);
+    font-size: 0.85rem;
+    white-space: pre-wrap;
+    color: var(--teal);
+    display: none;
+}
+
+.generated-content.show {
+    display: block;
+}
+
+/* Neural Network Status */
+.neural-status {
+    position: fixed;
+    bottom: 80px;
+    right: 20px;
+    background: var(--glass-bg);
+    border: 1px solid var(--magenta);
+    border-radius: 12px;
+    padding: 12px 16px;
+    font-size: 0.75rem;
+    color: var(--text-secondary);
+    backdrop-filter: blur(10px);
+    z-index: 100;
+}
+
+.neural-status .stat-line {
+    display: flex;
+    justify-content: space-between;
+    gap: 20px;
+    margin-bottom: 4px;
+}
+
+.neural-status .stat-line span:last-child {
+    color: var(--magenta);
+    font-family: var(--font-mono);
 }
