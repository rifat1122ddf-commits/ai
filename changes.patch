-    },
-    
-    // Huber Loss (Smooth L1)
-    huber: (yTrue, yPred, delta = 1.0) => {
-        let sum = 0;
-        for (let i = 0; i < yTrue.length; i++) {
-            const error = Math.abs(yTrue[i] - yPred[i]);
-            if (error <= delta) {
-                sum += 0.5 * error * error;
-            } else {
-                sum += delta * error - 0.5 * delta * delta;
