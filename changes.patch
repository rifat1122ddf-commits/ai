-        const patterns = [
-            /<script/i,
-            /javascript:/gi,
-            /on\w+=/gi,
-            /expression\s*\(/gi,
-            /url\s*\(/gi
-        ];
-        return patterns.some(pattern => pattern.test(str));
-    }
-};
