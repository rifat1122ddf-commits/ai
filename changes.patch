-  calculateNextTrigger(time, repeat) {
-    const nextTrigger = new Date(time);
-
-    switch (repeat) {
-      case 'daily':
-        nextTrigger.setDate(nextTrigger.getDate() + 1);
-        break;
-      case 'weekly':
-        nextTrigger.setDate(nextTrigger.getDate() + 7);
-        break;
-      case 'monthly':
-        nextTrigger.setMonth(nextTrigger.getMonth() + 1);
-        break;
-    }
